# ModelCharter environment.
#
# The PUBLIC product (marketing, AI Usage Policy generator, AI Tool Risk
# Directory, frameworks, blog) needs NONE of these and works with an empty env.
# Set these to turn on accounts, the team dashboard and billing.

# --- Supabase (accounts + dashboard) ---
# Create a free project at https://supabase.com, run supabase/migrations/0001_init.sql,
# then copy these from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (server only) — used by the Stripe webhook to update plans.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (paid plans) ---
# From https://dashboard.stripe.com. Create two recurring prices (Team, Business)
# and paste their price IDs.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_TEAM=
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS=
